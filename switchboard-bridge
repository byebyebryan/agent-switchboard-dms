#!/usr/bin/env python3

import sys
from importlib import import_module
from pathlib import Path


# Python uses the symlink's directory for ``sys.path[0]`` on some launch paths.
# Resolve the shipped entry point so a development symlink works from any cwd.
repo_root = str(Path(__file__).resolve().parent)
if repo_root not in sys.path:
    sys.path.insert(0, repo_root)


def bridge_main() -> int:
    return import_module("switchboard_dms.bridge").main()


if __name__ == "__main__":
    raise SystemExit(bridge_main())

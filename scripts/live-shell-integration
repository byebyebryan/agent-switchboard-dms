#!/bin/sh
set -eu

usage() {
    cat <<'EOF'
Usage: scripts/live-shell-integration --swbctl EXECUTABLE --confirm-disruptive

Exercise Switchboard inside the running DMS 1.5 shell, then restore the exact
pre-test plugin configuration. This restarts DMS and performs a real full
Agent Switchboard reconciliation. Run only on a disposable development shell.
EOF
}

die() {
    printf 'live-shell-integration: %s\n' "$*" >&2
    exit 1
}

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd -P)
config_dir=${XDG_CONFIG_HOME:-${HOME:?HOME is not set}/.config}/DankMaterialShell
plugin_dir=$config_dir/plugins
plugin_settings=$config_dir/plugin_settings.json
shell_settings=$config_dir/settings.json
swbctl=
confirmed=0
backup=
evidence=
baseline_plugins=
baseline_plugin_count=0
sampler_pid=
sampler_pgid=
sampler_active=0
shell_pending_signal=
shell_pending_exit_code=
settings_tmp=
restore_tmp=
plugin_settings_hash=
plugin_settings_metadata=
shell_settings_hash=
shell_settings_metadata=
paths_verified=0
mutation_started=0
run_completed=0
rollback_done=0

while [ "$#" -gt 0 ]; do
    case $1 in
        --swbctl)
            [ "$#" -ge 2 ] || die "--swbctl requires a value"
            swbctl=$2
            shift 2
            ;;
        --confirm-disruptive)
            confirmed=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage >&2
            die "unknown argument: $1"
            ;;
    esac
done

normalize_plugins() {
    dms ipc call plugin-scan list | awk -F '\t' 'NF >= 3 { print $1 "\t" $2 "\t" $3 }' | LC_ALL=C sort
}

wait_for_plugin_state() {
    expected_state=$1
    expected_type=$2
    attempts=0
    while [ "$attempts" -lt 100 ]; do
        status=$(dms ipc call plugin-scan status switchboard 2>/dev/null || true)
        if printf '%s\n' "$status" | awk -F '\t' -v state="$expected_state" -v type="$expected_type" '$1 == state && $2 == type { found = 1 } END { exit !found }'; then
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.1
    done
    return 1
}

restore_plugin_settings() {
    restore_tmp=$(mktemp "$config_dir/plugin_settings.json.switchboard-restore.XXXXXX") || return 1
    if ! cp --preserve=mode,ownership,timestamps -- "$backup/plugin_settings.json" "$restore_tmp"; then
        rm -f -- "$restore_tmp"
        return 1
    fi
    if ! mv -f -- "$restore_tmp" "$plugin_settings"; then
        rm -f -- "$restore_tmp"
        restore_tmp=
        return 1
    fi
    restore_tmp=
}

sampler_group_alive() {
    [ "$sampler_active" -eq 1 ] || return 1
    [ "$sampler_pgid" ] || return 1
    /bin/kill -0 -- "-$sampler_pgid" 2>/dev/null
}

stop_sampler() {
    [ "$sampler_active" -eq 1 ] || return 0

    # The group may still be crossing setsid. The unreaped leader owns this
    # numeric ID, so the PGID cannot be reused during this bounded handshake.
    attempts=0
    while ! sampler_group_alive && [ "$attempts" -lt 50 ]; do
        attempts=$((attempts + 1))
        sleep 0.01
    done
    if sampler_group_alive; then
        /bin/kill -TERM -- "-$sampler_pgid" 2>/dev/null || true
        attempts=0
        while sampler_group_alive && [ "$attempts" -lt 40 ]; do
            attempts=$((attempts + 1))
            sleep 0.05
        done
        if sampler_group_alive; then
            /bin/kill -KILL -- "-$sampler_pgid" 2>/dev/null || true
        fi
    fi
    wait "$sampler_pid" 2>/dev/null || true
    sampler_active=0
    sampler_pid=
    sampler_pgid=
}

live_shell_rollback() {
    [ "$rollback_done" -eq 0 ] || return 0
    rollback_done=1
    rollback_failed=0

    stop_sampler
    [ -z "$settings_tmp" ] || rm -f -- "$settings_tmp"
    settings_tmp=
    [ -z "$restore_tmp" ] || rm -f -- "$restore_tmp"
    restore_tmp=

    if [ "$mutation_started" -eq 1 ]; then
        dms ipc call launcher close >/dev/null 2>&1 || rollback_failed=1
        dms ipc call plugins disable switchboard >/dev/null 2>&1 || rollback_failed=1
        if [ -L "$plugin_dir/switchboard" ]; then
            "$repo_root/scripts/dev-plugin" --plugin-dir "$plugin_dir" remove >/dev/null 2>&1 || rollback_failed=1
        elif [ -e "$plugin_dir/switchboard" ]; then
            rollback_failed=1
        fi
        dms ipc call plugin-scan scan >/dev/null 2>&1 || rollback_failed=1
        if [ -f "$backup/plugin_settings.json" ]; then
            restore_plugin_settings || rollback_failed=1
        else
            rollback_failed=1
        fi
        [ -z "$settings_tmp" ] || rm -f -- "$settings_tmp"
        settings_tmp=
        [ -z "$restore_tmp" ] || rm -f -- "$restore_tmp"
        restore_tmp=
        dms restart >/dev/null 2>&1 || rollback_failed=1
    fi

    if [ "$baseline_plugin_count" -gt 0 ] && [ -f "$baseline_plugins" ]; then
        final_plugins=$backup/final-plugins.txt
        attempts=0
        while [ "$attempts" -lt 100 ]; do
            normalize_plugins >"$final_plugins" 2>/dev/null || true
            cmp -s "$baseline_plugins" "$final_plugins" && break
            attempts=$((attempts + 1))
            sleep 0.1
        done
        cmp -s "$baseline_plugins" "$final_plugins" || rollback_failed=1
    fi

    if [ "$paths_verified" -eq 1 ]; then
        [ ! -e "$plugin_dir/switchboard" ] || rollback_failed=1
        [ ! -L "$plugin_dir/switchboard" ] || rollback_failed=1
        if jq -e 'has("switchboard")' "$plugin_settings" >/dev/null 2>&1; then
            rollback_failed=1
        fi
    fi
    if [ "$plugin_settings_hash" ]; then
        [ "$(sha256sum "$plugin_settings" | awk '{print $1}')" = "$plugin_settings_hash" ] || rollback_failed=1
    fi
    if [ "$plugin_settings_metadata" ]; then
        [ "$(stat -c '%a:%u:%g' "$plugin_settings")" = "$plugin_settings_metadata" ] || rollback_failed=1
    fi
    if [ "$shell_settings_hash" ]; then
        [ "$(sha256sum "$shell_settings" | awk '{print $1}')" = "$shell_settings_hash" ] || rollback_failed=1
    fi
    if [ "$shell_settings_metadata" ]; then
        [ "$(stat -c '%a:%u:%g' "$shell_settings")" = "$shell_settings_metadata" ] || rollback_failed=1
    fi

    [ "$evidence" ] && rm -rf -- "$evidence"
    if [ "$rollback_failed" -eq 0 ]; then
        [ "$backup" ] && rm -rf -- "$backup"
        return 0
    fi
    printf 'live-shell-integration: rollback verification failed; backup retained at %s\n' "$backup" >&2
    return 1
}

live_shell_finish() {
    finish_status=$1
    trap - EXIT
    trap '' HUP INT TERM
    if ! live_shell_rollback; then
        [ "$finish_status" -ne 0 ] || finish_status=1
    fi
    if [ "$finish_status" -eq 0 ] && [ "$run_completed" -eq 1 ]; then
        printf 'LIVE_SHELL_INTEGRATION_OK baseline_plugins=%s process_samples=verified journal=verified restoration=verified\n' "$baseline_plugin_count"
    fi
    exit "$finish_status"
}

shell_defer_signal() {
    [ "$shell_pending_signal" ] || {
        shell_pending_signal=$1
        shell_pending_exit_code=$2
    }
}

shell_defer_traps() {
    trap 'shell_defer_signal HUP 129' HUP
    trap 'shell_defer_signal INT 130' INT
    trap 'shell_defer_signal TERM 143' TERM
}

shell_install_signal_traps() {
    trap 'exit 129' HUP
    trap 'exit 130' INT
    trap 'exit 143' TERM
}

shell_activate_traps() {
    shell_install_signal_traps
    if [ "$shell_pending_signal" ]; then
        pending_exit_code=$shell_pending_exit_code
        shell_pending_signal=
        shell_pending_exit_code=
        exit "$pending_exit_code"
    fi
}

start_sampler() {
    sample_mode=$1
    sample_output=$2
    shell_defer_traps
    setsid "$repo_root/scripts/live-process-sampler" \
        "$repo_root" "$swbctl" "$sample_mode" "$sample_output" &
    sampler_pid=$!
    sampler_pgid=$sampler_pid
    sampler_active=1
    shell_activate_traps
}

wait_sampler() {
    shell_defer_traps
    if wait "$sampler_pid"; then
        sampler_status=0
    else
        sampler_status=$?
    fi

    # The sampler only returns 0 or 1. A pending signal paired with a shell
    # signal status means wait was interrupted, so rollback still owns the
    # unreaped group. Otherwise wait reaped it and ownership is cleared before
    # honoring a signal, preventing a reused PID/PGID kill.
    if [ "$shell_pending_signal" ] && [ "$sampler_status" -ge 128 ]; then
        shell_activate_traps
    fi
    sampler_active=0
    sampler_pid=
    sampler_pgid=
    shell_activate_traps
    return "$sampler_status"
}

# Cleanup and signal handling are valid before the first mktemp, copy, hash, or
# metadata read. Every variable used by rollback was initialized above.
trap 'live_shell_finish "$?"' EXIT
shell_install_signal_traps

[ "$confirmed" -eq 1 ] || die "--confirm-disruptive is required"
[ "$swbctl" ] || die "--swbctl is required"
[ -x "$swbctl" ] || die "swbctl is not executable"
swbctl=$(realpath -e -- "$swbctl")
for command_name in dms jq journalctl python3 rg setsid; do
    command -v "$command_name" >/dev/null 2>&1 || die "$command_name is required"
done
[ -d "$config_dir" ] || die "DMS config directory is missing"
[ -d "$plugin_dir" ] || die "DMS user plugin directory is missing"
[ -f "$plugin_settings" ] || die "DMS plugin settings are missing"
[ -f "$shell_settings" ] || die "DMS shell settings are missing"
python3 - "$config_dir" "$plugin_dir" "$plugin_settings" "$shell_settings" <<'PY'
import pathlib
import sys

for raw_path in sys.argv[1:]:
    path = pathlib.Path(raw_path).absolute()
    current = pathlib.Path(path.anchor)
    for part in path.parts[1:]:
        current /= part
        if current.is_symlink():
            raise SystemExit(f"symlinked path component: {current}")
PY
current_uid=$(id -u)
for owned_path in "$config_dir" "$plugin_dir" "$plugin_settings" "$shell_settings"; do
    [ "$(stat -c '%u' "$owned_path")" = "$current_uid" ] || die "DMS config path is not owned by the current user"
done
[ ! -e "$plugin_dir/switchboard" ] || die "switchboard plugin path already exists"
[ ! -L "$plugin_dir/switchboard" ] || die "switchboard plugin link already exists"
if jq -e 'has("switchboard")' "$plugin_settings" >/dev/null; then
    die "switchboard plugin settings already exist"
fi
paths_verified=1

umask 077
backup=$(mktemp -d "${TMPDIR:-/tmp}/switchboard-shell-backup.XXXXXX")
evidence=$(mktemp -d "${TMPDIR:-/tmp}/switchboard-shell-evidence.XXXXXX")
chmod 700 "$backup" "$evidence"
cp --preserve=mode,ownership,timestamps -- "$plugin_settings" "$backup/plugin_settings.json"
plugin_settings_hash=$(sha256sum "$plugin_settings" | awk '{print $1}')
plugin_settings_metadata=$(stat -c '%a:%u:%g' "$plugin_settings")
shell_settings_hash=$(sha256sum "$shell_settings" | awk '{print $1}')
shell_settings_metadata=$(stat -c '%a:%u:%g' "$shell_settings")
baseline_plugins=$backup/baseline-plugins.txt

normalize_plugins >"$baseline_plugins"
baseline_plugin_count=$(wc -l <"$baseline_plugins")
[ "$baseline_plugin_count" -gt 0 ] || die "baseline plugin list is empty"
if awk -F '\t' '$1 == "switchboard" { found = 1 } END { exit !found }' "$baseline_plugins"; then
    die "baseline plugin list already contains switchboard"
fi

journalctl --user -u dms.service -n 0 --show-cursor --no-pager >"$backup/journal-cursor.txt"
journal_cursor=$(sed -n 's/^-- cursor: //p' "$backup/journal-cursor.txt")
[ "$journal_cursor" ] || die "could not capture the dms.service journal cursor"

mutation_started=1
"$repo_root/scripts/dev-plugin" --plugin-dir "$plugin_dir" install >/dev/null
dms ipc call plugin-scan scan >/dev/null
wait_for_plugin_state unloaded launcher || die "switchboard was not discovered unloaded"
dms ipc call plugins enable switchboard >/dev/null
dms ipc call plugins reload switchboard >/dev/null
wait_for_plugin_state loaded launcher || die "switchboard did not load"

during_plugins=$evidence/during-plugins.txt
expected_plugins=$evidence/expected-plugins.txt
normalize_plugins >"$during_plugins"
{ cat "$baseline_plugins"; printf 'switchboard\tloaded\tlauncher\n'; } | LC_ALL=C sort >"$expected_plugins"
cmp -s "$expected_plugins" "$during_plugins" || die "loaded plugin list did not equal baseline plus switchboard"

settings_tmp=$(mktemp "$config_dir/plugin_settings.json.switchboard-test.XXXXXX")
jq --arg swbctl "$swbctl" '.switchboard = {
    "enabled": true,
    "swbctl": $swbctl,
    "timeout_ms": 10000,
    "refresh_seconds": 5
}' "$plugin_settings" >"$settings_tmp"
chmod --reference="$plugin_settings" "$settings_tmp"
chown --reference="$plugin_settings" "$settings_tmp"
shell_defer_traps
if mv -f -- "$settings_tmp" "$plugin_settings"; then
    settings_move_status=0
    settings_tmp=
else
    settings_move_status=$?
fi
shell_activate_traps
[ "$settings_move_status" -eq 0 ] || die "could not replace plugin settings"

retained_processes=$evidence/retained-processes.txt
start_sampler retained "$retained_processes"
dms restart >/dev/null
wait_for_plugin_state loaded launcher || die "switchboard did not reload after restart"
dms ipc call launcher openQuery 'sb:switchboard' >/dev/null
wait_sampler || die "retained process sample was incomplete"
[ "$(wc -l <"$retained_processes")" -eq 2 ]
rg -qx 'BRIDGE_RETAINED' "$retained_processes"
rg -qx 'FLEET_RETAINED' "$retained_processes"

sleep 6
dms ipc call launcher close >/dev/null
refresh_processes=$evidence/refresh-processes.txt
start_sampler refresh "$refresh_processes"
dms ipc call launcher openQuery 'sb:switchboard' >/dev/null
wait_sampler || die "refresh process sample was incomplete"
[ "$(wc -l <"$refresh_processes")" -eq 2 ]
rg -qx 'BRIDGE_REFRESH' "$refresh_processes"
rg -qx 'FLEET_REFRESH' "$refresh_processes"

journal_log=$evidence/dms-journal.log
journalctl --user -u dms.service --after-cursor "$journal_cursor" --no-pager -o short-iso-precise >"$journal_log"
[ -s "$journal_log" ] || die "dms.service journal capture is empty"
rg -q 'dms\[[0-9]+\]:' "$journal_log" || die "dms.service journal capture has no service records"
if rg -qi 'error loading plugin:[[:space:]]*switchboard|bad manifest.*switchboard|component error.*switchboard|failed to (load|instantiate).*switchboard|switchboard.*failed to (load|instantiate)' "$journal_log"; then
    die "dms.service journal contains a Switchboard load error"
fi

run_completed=1

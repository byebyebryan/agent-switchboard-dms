#!/bin/sh
set -eu

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$repo_root"

python3 -m json.tool plugin.json >/dev/null
sh -n scripts/check scripts/dev-plugin scripts/live-integration
python3 -m compileall -q switchboard_dms scripts tests
ruff format --check switchboard_dms scripts tests
ruff check switchboard_dms scripts tests
python3 -m unittest discover -s tests -v
node tests/test_entry_model.js

first=$(mktemp)
second=$(mktemp)
trap 'rm -f -- "$first" "$second"' EXIT HUP INT TERM
SOURCE_DATE_EPOCH=1784073600 scripts/build-plugin --output "$first"
SOURCE_DATE_EPOCH=1784073600 scripts/build-plugin --output "$second"
cmp "$first" "$second"

qt6_qmlformat=${QT6_QMLFORMAT:-/usr/lib/qt6/bin/qmlformat}
if [ -x "$qt6_qmlformat" ]; then
    for qml_file in SwitchboardLauncher.qml SwitchboardSettings.qml tests/live/Shell.qml; do
        formatted=$(mktemp)
        "$qt6_qmlformat" "$qml_file" >"$formatted"
        if ! cmp -s "$qml_file" "$formatted"; then
            printf 'Qt 6 qmlformat differs: %s\n' "$qml_file" >&2
            rm -f "$formatted"
            exit 1
        fi
        rm -f "$formatted"
    done
fi

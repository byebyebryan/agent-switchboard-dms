#!/usr/bin/env python3
import pathlib
import sys
import time

repo = pathlib.Path(sys.argv[1])
swbctl = sys.argv[2]
mode = sys.argv[3]
output = pathlib.Path(sys.argv[4])
bridge = str(repo / "switchboard-bridge")
bridge_tail = ["--swbctl", swbctl, "--timeout-ms", "10000"]
fleet_tail = ["fleet", "--json"]
markers = {"BRIDGE_RETAINED", "FLEET_RETAINED"}
if mode == "refresh":
    bridge_tail.append("--refresh")
    fleet_tail = ["fleet", "--refresh", "--json"]
    markers = {"BRIDGE_REFRESH", "FLEET_REFRESH"}

seen = set()
deadline = time.monotonic() + 10
while time.monotonic() < deadline and seen != markers:
    for command_path in pathlib.Path("/proc").glob("[0-9]*/cmdline"):
        try:
            argv = command_path.read_bytes().split(b"\0")
            argv = [part.decode("utf-8", "replace") for part in argv if part]
        except (FileNotFoundError, PermissionError, ProcessLookupError):
            continue
        for index, argument in enumerate(argv):
            if argument == bridge and argv[index + 1 :] == bridge_tail:
                seen.add("BRIDGE_REFRESH" if mode == "refresh" else "BRIDGE_RETAINED")
            if argument == swbctl and argv[index + 1 :] == fleet_tail:
                seen.add(
                    "FLEET_REFRESH" if mode == "refresh" else "FLEET_RETAINED"
                )
    time.sleep(0.05)

output.write_text("".join(f"{marker}\n" for marker in sorted(seen)), encoding="utf-8")
raise SystemExit(0 if seen == markers else 1)

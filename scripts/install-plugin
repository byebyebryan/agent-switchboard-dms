#!/usr/bin/env python3

from __future__ import annotations

import argparse
import hashlib
import json
import os
import shutil
import stat
import sys
from pathlib import Path
from uuid import uuid4

sys.path.insert(0, str(Path(__file__).resolve().parent))
from plugin_artifact import (  # noqa: E402
    EXECUTABLE_FILES,
    PREFIX,
    ArtifactError,
    read_archive,
)


def _plugin_dir(value: str) -> Path:
    path = Path(value)
    if not path.is_absolute() or path == path.parent:
        raise argparse.ArgumentTypeError("plugin directory must be absolute")
    return path


def _root(path: Path) -> Path:
    if not path.is_dir() or path.is_symlink() or path.stat().st_uid != os.getuid():
        raise ArtifactError("plugin directory is missing or unsafe")
    return path.resolve()


def _staged_root(plugin_dir: Path) -> Path:
    return plugin_dir / ".switchboard-versions"


def stage(plugin_dir: Path, archive: Path) -> dict[str, str]:
    plugin_dir = _root(plugin_dir)
    payloads, _manifest = read_archive(archive)
    digest = hashlib.sha256(archive.read_bytes()).hexdigest()
    versions = _staged_root(plugin_dir)
    versions.mkdir(mode=0o700, exist_ok=True)
    if versions.is_symlink() or versions.stat().st_uid != os.getuid():
        raise ArtifactError("version store is unsafe")
    destination = versions / f"0.5.0-{digest[:16]}"
    if destination.exists():
        marker = destination / ".artifact-sha256"
        if marker.read_text(encoding="ascii") != digest + "\n":
            raise ArtifactError("staged plugin marker does not match artifact")
        for archive_name, payload in payloads.items():
            relative = archive_name.removeprefix(PREFIX)
            target = destination / relative
            if (
                not target.is_file()
                or target.is_symlink()
                or hashlib.sha256(target.read_bytes()).digest()
                != hashlib.sha256(payload).digest()
            ):
                raise ArtifactError("staged plugin contents do not match artifact")
        return {"staged": str(destination), "sha256": digest}
    temporary = versions / f".staging-{uuid4()}"
    temporary.mkdir(mode=0o700)
    try:
        for archive_name, payload in payloads.items():
            relative = archive_name.removeprefix(PREFIX)
            target = temporary / relative
            target.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
            descriptor = os.open(
                target,
                os.O_WRONLY | os.O_CREAT | os.O_EXCL | os.O_NOFOLLOW,
                0o755 if relative in EXECUTABLE_FILES else 0o644,
            )
            try:
                view = memoryview(payload)
                while view:
                    written = os.write(descriptor, view)
                    if written <= 0:
                        raise ArtifactError("staged plugin write was incomplete")
                    view = view[written:]
                os.fsync(descriptor)
            finally:
                os.close(descriptor)
        marker = temporary / ".artifact-sha256"
        marker.write_text(digest + "\n", encoding="ascii")
        marker.chmod(0o400)
        temporary.rename(destination)
        directory = os.open(versions, os.O_RDONLY | os.O_DIRECTORY)
        try:
            os.fsync(directory)
        finally:
            os.close(directory)
    finally:
        if temporary.exists():
            shutil.rmtree(temporary)
    return {"staged": str(destination), "sha256": digest}


def _validate_staged(plugin_dir: Path, staged: Path) -> Path:
    versions = _staged_root(plugin_dir).resolve()
    candidate = staged.resolve()
    if candidate.parent != versions or not candidate.is_dir() or candidate.is_symlink():
        raise ArtifactError("staged plugin directory is invalid")
    marker = candidate / ".artifact-sha256"
    if not marker.is_file() or stat.S_IMODE(marker.stat().st_mode) != 0o400:
        raise ArtifactError("staged plugin marker is invalid")
    plugin = json.loads((candidate / "plugin.json").read_text(encoding="utf-8"))
    if plugin.get("id") != "switchboard" or plugin.get("version") != "0.5.0":
        raise ArtifactError("staged plugin metadata is incompatible")
    return candidate


def activate(plugin_dir: Path, staged: Path) -> dict[str, str]:
    plugin_dir = _root(plugin_dir)
    candidate = _validate_staged(plugin_dir, staged)
    destination = plugin_dir / "switchboard"
    if destination.exists() or destination.is_symlink():
        if not destination.is_symlink():
            raise ArtifactError("active plugin path is not installer-owned")
        current = destination.resolve(strict=False)
        if current.parent != _staged_root(plugin_dir).resolve():
            raise ArtifactError("active plugin symlink is not installer-owned")
    temporary = plugin_dir / f".switchboard-link-{uuid4()}"
    temporary.symlink_to(candidate.relative_to(plugin_dir), target_is_directory=True)
    os.replace(temporary, destination)
    directory = os.open(plugin_dir, os.O_RDONLY | os.O_DIRECTORY)
    try:
        os.fsync(directory)
    finally:
        os.close(directory)
    return {"active": str(destination), "staged": str(candidate)}


def status(plugin_dir: Path) -> dict[str, object]:
    plugin_dir = _root(plugin_dir)
    destination = plugin_dir / "switchboard"
    if not destination.is_symlink():
        return {"active": False, "owned": False}
    target = destination.resolve(strict=False)
    owned = target.parent == _staged_root(plugin_dir).resolve()
    return {"active": target.is_dir(), "owned": owned, "target": str(target)}


def main() -> int:
    parser = argparse.ArgumentParser(prog="install-plugin")
    parser.add_argument("--plugin-dir", required=True, type=_plugin_dir)
    commands = parser.add_subparsers(dest="command", required=True)
    staged = commands.add_parser("stage")
    staged.add_argument("--archive", required=True, type=Path)
    active = commands.add_parser("activate")
    active.add_argument("--staged", required=True, type=Path)
    commands.add_parser("status")
    arguments = parser.parse_args()
    try:
        if arguments.command == "stage":
            result = stage(arguments.plugin_dir, arguments.archive)
        elif arguments.command == "activate":
            result = activate(arguments.plugin_dir, arguments.staged)
        else:
            result = status(arguments.plugin_dir)
    except (ArtifactError, OSError, ValueError, json.JSONDecodeError) as error:
        print(f"install-plugin: {error}", file=sys.stderr)
        return 1
    print(json.dumps(result, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

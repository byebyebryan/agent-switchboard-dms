#!/bin/sh
set -eu

usage() {
    cat <<'EOF'
Usage: scripts/live-integration --swbctl EXECUTABLE
                                --config-root DIRECTORY --state-root DIRECTORY
                                [--dms-root DIRECTORY]

Run the DMS 0.5 launcher/settings components in a fresh Quickshell process
against an isolated core 0.3 generation. The caller owns the supplied roots.
EOF
}

die() {
    printf 'live-integration: %s\n' "$*" >&2
    exit 1
}

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd -P)
dms_root=${DMS_QML_ROOT:-/usr/share/quickshell/dms}
swbctl=
config_root=
state_root=
temporary=
harness_pid=

cleanup() {
    status=$?
    trap - EXIT HUP INT TERM
    if [ "${harness_pid:-}" ]; then
        kill -- -"$harness_pid" 2>/dev/null || true
        wait "$harness_pid" 2>/dev/null || true
    fi
    if [ "${temporary:-}" ]; then
        rm -rf -- "$temporary"
    fi
    exit "$status"
}
trap cleanup EXIT HUP INT TERM

while [ "$#" -gt 0 ]; do
    case $1 in
        --swbctl) [ "$#" -ge 2 ] || die "--swbctl requires a value"; swbctl=$2; shift 2 ;;
        --config-root) [ "$#" -ge 2 ] || die "--config-root requires a value"; config_root=$2; shift 2 ;;
        --state-root) [ "$#" -ge 2 ] || die "--state-root requires a value"; state_root=$2; shift 2 ;;
        --dms-root) [ "$#" -ge 2 ] || die "--dms-root requires a value"; dms_root=$2; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) usage >&2; die "unknown argument: $1" ;;
    esac
done

[ -x "$swbctl" ] || die "swbctl is not executable"
[ -d "$config_root" ] || die "config root is missing"
[ -d "$state_root" ] || die "state root is missing"
[ -f "$dms_root/shell.qml" ] || die "DMS QML root is invalid"
for command in qs python3 setsid; do
    command -v "$command" >/dev/null 2>&1 || die "$command is not installed"
done

temporary=$(mktemp -d "${TMPDIR:-/tmp}/switchboard-live-v1.XXXXXX")
chmod 700 "$temporary"
mkdir -m 700 "$temporary/config" "$temporary/state" "$temporary/cache" "$temporary/data"
for directory in Common Modules Services Widgets; do
    [ -d "$dms_root/$directory" ] || die "installed DMS import is missing: $directory"
    ln -s -- "$dms_root/$directory" "$temporary/$directory"
done
cp -- "$repo_root/tests/live/Shell.qml" "$temporary/shell.qml"
cp -- "$repo_root/SwitchboardLauncher.qml" "$repo_root/SwitchboardSettings.qml" \
    "$repo_root/SwitchboardEntryModelV1.js" "$repo_root/switchboard-bridge" \
    "$repo_root/switchboard-open" "$temporary/"
cp -a -- "$repo_root/switchboard_dms" "$temporary/switchboard_dms"

setsid env \
    XDG_CONFIG_HOME="$temporary/config" \
    XDG_STATE_HOME="$temporary/state" \
    XDG_CACHE_HOME="$temporary/cache" \
    XDG_DATA_HOME="$temporary/data" \
    SWB_V3_CONFIG_ROOT="$config_root" \
    SWB_V3_STATE_ROOT="$state_root" \
    SWITCHBOARD_LIVE_SWBCTL="$swbctl" \
    qs -p "$temporary" --no-color --log-times >"$temporary/quickshell.log" 2>&1 &
harness_pid=$!

ipc() {
    qs -p "$temporary" ipc call switchboard-live "$@"
}

wait_for() {
    description=$1
    predicate=$2
    attempts=0
    while [ "$attempts" -lt 200 ]; do
        kill -0 "$harness_pid" 2>/dev/null || {
            tail -n 80 "$temporary/quickshell.log" >&2 || true
            die "Quickshell exited while waiting for $description"
        }
        state=$(ipc status 2>/dev/null || true)
        if [ "$state" ] && STATE=$state python3 -c "$predicate" 2>/dev/null; then
            printf '%s\n' "$state"
            return 0
        fi
        attempts=$((attempts + 1))
        sleep 0.05
    done
    tail -n 80 "$temporary/quickshell.log" >&2 || true
    die "timed out waiting for $description"
}

initial=$(wait_for "fresh entry model" 'import json,os,sys;s=json.loads(os.environ["STATE"]);sys.exit(not(s["idle"] and s["hasModel"] and s["fresh"] and not s["failureCode"]))')
printf 'INITIAL %s\n' "$initial"
categories=$(ipc captureCategories)
CATEGORIES=$categories python3 -c 'import json,os;s=json.loads(os.environ["CATEGORIES"]);assert s["categoriesValid"]'
printf 'CATEGORIES %s\n' "$categories"
baseline=$(ipc captureBaseline)
BASELINE=$baseline python3 -c 'import json,os;s=json.loads(os.environ["BASELINE"]);assert s["queryMatchedExact"]'
printf 'QUERY %s\n' "$baseline"
cached=$(ipc reloadCachedModel)
CACHED=$cached python3 -c 'import json,os;s=json.loads(os.environ["CACHED"]);assert s["cacheReloaded"] and not s["fresh"]'
printf 'WARM_CACHE %s\n' "$cached"
ipc refresh >/dev/null
fresh=$(wait_for "cache provenance refresh" 'import json,os,sys;s=json.loads(os.environ["STATE"]);sys.exit(not(s["idle"] and s["hasModel"] and s["fresh"] and not s["failureCode"]))')
printf 'REFRESHED %s\n' "$fresh"
retention=$(ipc captureRetentionBaseline)
ipc setExecutable "$temporary/missing-swbctl" >/dev/null
retained=$(wait_for "last-good retention" 'import json,os,sys;s=json.loads(os.environ["STATE"]);sys.exit(not(s["idle"] and not s["fresh"] and s["failureCode"] and s["retainedModelMatches"]))')
printf 'RETAINED_FAILURE %s\n' "$retained"
printf 'LIVE_INTEGRATION_V1_OK\n'
